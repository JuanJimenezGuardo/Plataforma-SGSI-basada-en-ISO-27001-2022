#!/usr/bin/env sh

# Allowed branches for this repository workflow.
ALLOWED="develop feature/backend feature/frontend"

is_allowed() {
  branch="$1"
  for allowed in $ALLOWED; do
    if [ "$branch" = "$allowed" ]; then
      return 0
    fi
  done
  return 1
}

while read local_ref local_sha remote_ref remote_sha
do
  # Allow delete operations: local_ref is "(delete)" when deleting remote branches.
  if [ "$local_ref" = "(delete)" ]; then
    continue
  fi

  branch=$(echo "$local_ref" | sed 's#refs/heads/##')

  if ! is_allowed "$branch"; then
    echo "ERROR: Push bloqueado. Rama no permitida: $branch"
    echo "Ramas permitidas: develop, feature/backend, feature/frontend"
    exit 1
  fi

done

exit 0
